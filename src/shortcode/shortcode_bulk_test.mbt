    ("image src=\"/img/303.png\" alt=\"alt-303\" width=403", "image"),
    ("image src=\"/img/304.png\" alt=\"alt-304\" width=404", "image"),
    ("image src=\"/img/305.png\" alt=\"alt-305\" width=405", "image"),
    ("image src=\"/img/306.png\" alt=\"alt-306\" width=406", "image"),
    ("image src=\"/img/307.png\" alt=\"alt-307\" width=407", "image"),
    ("image src=\"/img/308.png\" alt=\"alt-308\" width=408", "image"),
    ("image src=\"/img/309.png\" alt=\"alt-309\" width=409", "image"),
    ("image src=\"/img/310.png\" alt=\"alt-310\" width=410", "image"),
    ("image src=\"/img/311.png\" alt=\"alt-311\" width=411", "image"),
    ("image src=\"/img/312.png\" alt=\"alt-312\" width=412", "image"),
    ("image src=\"/img/313.png\" alt=\"alt-313\" width=413", "image"),
    ("image src=\"/img/314.png\" alt=\"alt-314\" width=414", "image"),
    ("image src=\"/img/315.png\" alt=\"alt-315\" width=415", "image"),
    ("image src=\"/img/316.png\" alt=\"alt-316\" width=416", "image"),
    ("image src=\"/img/317.png\" alt=\"alt-317\" width=417", "image"),
    ("image src=\"/img/318.png\" alt=\"alt-318\" width=418", "image"),
    ("image src=\"/img/319.png\" alt=\"alt-319\" width=419", "image"),
    ("image src=\"/img/320.png\" alt=\"alt-320\" width=420", "image"),
  ]
  let mut i = 0
  while i < cases.length() {
    let (raw, expected) = cases[i]
    match parse(raw) {
      Ok(call) => assert_eq(call.name, expected)
      Err(_) => assert_true(false)
    }
    i = i + 1
  }
}

///|
test "shortcode bulk render matrix" {
  let mut i = 1
  while i <= 120 {
    let params : Map[String, ShortcodeParam] = Map::new()
    params.set("src", StringParam("/bulk/" + i.to_string() + ".png"))
    params.set("alt", StringParam("bulk-alt-" + i.to_string()))
    params.set("width", IntParam(200 + i))
    let call : ShortcodeCall = { name: "image", params }
    match render(call) {
      Ok(html) => {
        assert_true(html.contains("<img"))
        assert_true(html.contains("bulk-alt-" + i.to_string()))
      }
      Err(_) => assert_true(false)
    }
    i = i + 1
  }
}
